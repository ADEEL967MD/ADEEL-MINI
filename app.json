{
    "name": "бҘ«рқҗғрқҗ‘бӯЎрқҗ„рқҗ‘рқҗ…рқҗҖрқҗҚвҳ…вғқрҹ”Ҙрҹ‘» ",
    "description": "mini web bot",
    "logo": "https://raw.githubusercontent.com/xhclintohn/Music-Clips-Collection/main/mini.png",
    "repository": "https://github.com/xhci",
    "keywords": [
        "adeelmini",
        "MiniBot"
    ],
    "success_url": "/",
    "buildpacks": [
        {
            "url": "https://github.com/heroku/heroku-buildpack-nodejs#latest"
        }
    ],
    "addons": [
        {
            "plan": "heroku-postgresql",
            "as": "DATABASE"
        }
    ],
    "env": {
        "PORT": {
            "description": "Port for web app.4000,5000,3000... any!",
            "value": "3000",
            "required": false
        },
        "DATABASE_URL": {
            "description": "PostgreSQL database URL (auto-configured by Heroku Postgres)",
            "required": false
        }
    }
}
